# ── Провайдеры ────────────────────────────────────────────────────────────────
FRIZURA_OPENAI_API_KEY=sk-...
FRIZURA_ANTHROPIC_API_KEY=sk-ant-...
FRIZURA_GOOGLE_API_KEY=AIza...

# ── Дефолтная модель ──────────────────────────────────────────────────────────
# Формат: "provider:model_id"
# Примеры: openai:gpt-4o-mini | anthropic:claude-sonnet-4-6 | ollama:llama3.3
FRIZURA_DEFAULT_MODEL=openai:gpt-4o-mini

# ── Логирование ───────────────────────────────────────────────────────────────
FRIZURA_LOG_LEVEL=INFO
FRIZURA_VERBOSE=false
